# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Database Connection (PostgreSQL)
# Prisma format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/campus_connect?schema=public"

# JWT Secrets
JWT_SECRET="supersecretkeyforaccesstoken"
JWT_REFRESH_SECRET="supersecretkeyforrefreshtoken"
